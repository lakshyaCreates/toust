datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

enum Plan {
    GUEST
    APPETIZER
    MAIN_COURSE
}

enum OrderStatus {
    CREATED
    PAYMENT_PENDING
    PAID
}

model Toust {
    id String @id @default(cuid())

    title       String
    description String
    time        String
    imageUrl    String

    index Int

    websiteId String

    website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)
}

model Website {
    id String @id @default(cuid())

    url           String
    toastEvery    Int    @default(100)
    toastDuration Int    @default(150)
    waitFor       Int    @default(200)

    userId String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    Toust Toust[]
}

model User {
    id            String      @id @default(cuid())
    name          String?
    email         String      @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    plan          Plan        @default(GUEST)
    orderId       String?
    orderStatus   OrderStatus @default(CREATED)
    paymentId     String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    Website Website[]
}

model Account {
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String?
    access_token      String?
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String?
    session_state     String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([provider, providerAccountId])
}

model Session {
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model VerificationToken {
    identifier String
    token      String
    expires    DateTime

    @@id([identifier, token])
}
